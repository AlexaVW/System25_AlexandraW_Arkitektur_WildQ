<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="NavButtonBrown" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource MyBrown}" />
        <Setter Property="Padding" Value="10"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontFamily" Value="Exo2"/>
    </Style>

    <Style x:Key="SelectionButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Wheat"/>
        <Setter Property="TextColor" Value="DarkOliveGreen"/>
    </Style>

</ResourceDictionary>
