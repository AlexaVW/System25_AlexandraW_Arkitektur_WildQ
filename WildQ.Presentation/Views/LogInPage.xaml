<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WildQ.Presentation.Views.LogInPage"
             Title="LogInPage"
             BackgroundColor="DarkOliveGreen">
    
    <VerticalStackLayout MaximumWidthRequest="800" Margin="10">
        <Label 
            Text="Log In"
            TextColor="Wheat"
            Style="{StaticResource SubHeadline}"
            VerticalOptions="Center" 
            HorizontalOptions="Center"/>
        
        <Button
            Text="Go Back"
            Style="{StaticResource NavButtonBrown}"
            HorizontalOptions="Start"
            Clicked="OnClickedGoBack"/>
        
        <VerticalStackLayout Margin="0,40" Spacing="20">
            <Entry 
                x:Name="UserNameEntry"
                Placeholder="Enter username"/>
            <Entry
                x:Name="PasswordEntry"
                Placeholder="Enter Password"/>
            <Button
                x:Name="LogInButton"
                Text="Log In"
                Clicked="OnClickedLogIn"
                BackgroundColor="Wheat"
                TextColor="DarkOliveGreen"/>
        </VerticalStackLayout>
        
    </VerticalStackLayout>
</ContentPage>