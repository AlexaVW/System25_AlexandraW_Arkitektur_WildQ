<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WildQ.Presentation.Views.AnimalQuizPage"
             Title="AnimalQuizPage"
             BackgroundColor="DarkOliveGreen">
    <ScrollView>
        <VerticalStackLayout Margin="10" Spacing="10" HorizontalOptions="Center">

            <!-- Navigation Buttons -->
            <Grid 
                Padding="10"
                ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button
                    Text="Go Back"
                    Clicked="OnClickedGoBackToEndangeredAnimalQuiz"
                    Style="{StaticResource NavButtonBrown}"
                    Grid.Column="0"/>
                
                <Button
                    x:Name="EditAnimalButton"
                    Text="Edit Animal"
                    Clicked="OnClickedUpdateAnimal"
                    Style="{StaticResource NavButtonBrown}"
                    Grid.Column="2"/>

                <Button
                    x:Name="DeleteAnimalButton"
                    Text="Delete Animal"
                    Clicked="OnClickedDeleteAnimal"
                    BackgroundColor="DarkRed"
                    Grid.Column="3"/>
            </Grid>

            <!-- The Animal -->
            <Border
                StrokeShape="RoundRectangle 5"
                StrokeThickness="4"
                Stroke="Wheat"
                BackgroundColor="{StaticResource MyOtherBrown}"
                MaximumWidthRequest="900"
                Padding="0,40">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label 
                        Text="{Binding Animal.AnimalName}"
                        HorizontalOptions="Center"
                        Style="{StaticResource Headline}"
                        TextColor="Wheat"/>
                    <Label
                        Text="{Binding Animal.Order,
                        StringFormat='Order: {0}'}"
                        HorizontalTextAlignment="Center"
                        TextColor="Wheat"/>

                    <Border 
                        StrokeShape="RoundRectangle 20" 
                        HeightRequest="300" 
                        MaximumWidthRequest="500" 
                        HorizontalOptions="Center"
                        StrokeThickness="0"
                        Margin="10">
                        <Image 
                            Source="{Binding Animal.ImageSource}"
                            Aspect="AspectFill"/>
                    </Border>

                    <!-- Question -->
                    <Label
                        Text="{Binding CurrentQuestion.QuestionText}"
                        TextColor="Wheat"
                        FontSize="20"
                        HorizontalTextAlignment="Center"/>

                    <!-- Answers -->
                    <CollectionView ItemsSource ="{Binding RandomOrderOnAnswers}" HorizontalOptions="Center">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout>
                                    <Button
                                        Text="{Binding AnswerText}"
                                        Style="{StaticResource SelectionButton}"
                                        Clicked="OnClickedAnswer"
                                        HorizontalOptions="Fill"
                                        MaximumWidthRequest="500"
                                        HeightRequest="45"/>
                                </VerticalStackLayout>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>