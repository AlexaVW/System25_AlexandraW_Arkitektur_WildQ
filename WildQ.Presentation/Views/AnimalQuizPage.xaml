<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WildQ.Presentation.Views.AnimalQuizPage"
             Title="AnimalQuizPage">
    <ScrollView>
        <VerticalStackLayout BackgroundColor="DarkOliveGreen">

            <HorizontalStackLayout Spacing="10">
                <Button
            Text="Edit Animal"
            Clicked="OnClickedUpdateAnimal"
            BackgroundColor="Wheat"
            TextColor="DarkOliveGreen"/>

                <Button
            Text="Delete Animal"
            Clicked="OnClickedDeleteAnimal"
            BackgroundColor="Wheat"
            TextColor="DarkOliveGreen"/>
            </HorizontalStackLayout>


            <Label 
        Text="{Binding Animal.AnimalName}"
        VerticalOptions="Center" 
        HorizontalOptions="Center"
        Style="{StaticResource Headline}"
        TextColor="Wheat"/>

            <Image Source="{Binding Animal.ImageSource}"
        HeightRequest="300"
        HorizontalOptions="Center"/>

            <Label
                Text="{Binding CurrentQuestion.QuestionText}"
                TextColor="Black"
                FontSize="20"
                HorizontalTextAlignment="Center"/>

            <CollectionView ItemsSource ="{Binding CurrentQuestion.Answers}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Text="{Binding AnswerText}"
                            BackgroundColor="Wheat"
                            TextColor="DarkOliveGreen"
                            Clicked="OnClickedAnswer"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>