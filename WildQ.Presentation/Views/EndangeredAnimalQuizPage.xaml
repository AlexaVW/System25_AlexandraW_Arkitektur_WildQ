<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WildQ.Presentation.Views.EndangeredAnimalQuizPage"
             Title="EndangeredAnimalQuiz"
             BackgroundColor="DarkOliveGreen">
    <ScrollView>
    <VerticalStackLayout HorizontalOptions="Center" MaximumWidthRequest="1400">
            
            <Label 
                Text="Endangered Animals Quiz"
                TextColor="Wheat"
                Style="{StaticResource SubHeadline}"
                VerticalOptions="Center" 
                HorizontalOptions="Center"/>
            
                <FlexLayout 
                    Wrap="Wrap"
                    JustifyContent="Center"
                    Direction="Row"
                    Margin="10"
                    HorizontalOptions="Center">
                    <Button
                        Text="Go Back"
                        Clicked="OnClickedGoBackToMainPage"
                        Style="{StaticResource NavButtonBrown}"
                        Margin="4"/>

                    <Button
                        x:Name="OrderCarnivoraButton"
                        Text="Carnivora"
                        Clicked="OnClickedCarnivoraButton"
                        BackgroundColor="Wheat"
                        TextColor="DarkOliveGreen"
                        Margin="4"/>

                    <Button
                        x:Name="OrderPrimatesButton"
                        Text="Primates"
                        Clicked="OnClickedPrimatesButton"
                        BackgroundColor="Wheat"
                        TextColor="DarkOliveGreen"
                        Margin="4"/>

                    <Button
                        x:Name="OddToedUngulatesButton"
                        Text="Odd-Toed Ungulates"
                        Clicked="OnClickedOddToedUngulatesButton"
                        BackgroundColor="Wheat"
                        TextColor="DarkOliveGreen"
                        Margin="4"/>

                    <Button
                        x:Name="EvenToedUngulatesButton"
                        Text="Even-Toed Ungulates"
                        Clicked="OnClickedEvenToedUngulatesButton"
                        BackgroundColor="Wheat"
                        TextColor="DarkOliveGreen"
                        Margin="4"/>

                    <Button
                        x:Name="AllAnimalsButton"
                        Text="All Animals"
                        Clicked="OnClickedAllAnimalsButton"
                        BackgroundColor="Wheat"
                        TextColor="DarkOliveGreen"
                        Margin="4"/>

                    <Button 
                        x:Name="AddQuizButton"
                        Text="Add Quiz"
                        Clicked="OnClickedGoAdminQuizPage"
                        Style="{StaticResource NavButtonBrown}"
                        Margin="4"/>
                </FlexLayout>
                
            <CollectionView ItemsSource="{Binding Animals}"
                            SelectionMode="Single"
                            SelectionChanged="OnCollectionViewSelectionChanged"
                            Margin="10">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="20"/>
                </CollectionView.ItemsLayout>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            StrokeShape="RoundRectangle 5"
                            StrokeThickness="4"
                            Stroke="Wheat"
                            BackgroundColor="{StaticResource MyOtherBrown}"
                            MaximumWidthRequest="900"
                            Padding="10">
                            <VerticalStackLayout Padding="10" Spacing="10" Margin="0, 0, 0, 30">
                                <Label
                                    Text="{Binding AnimalName}"
                                    TextColor="Wheat"
                                    FontSize="30"
                                    HorizontalOptions="Center"
                                    HorizontalTextAlignment="Center"/>
                                <Border 
                                    Margin="10"
                                    StrokeShape="RoundRectangle 20" 
                                    StrokeThickness="0"
                                    HeightRequest="300" 
                                    MaximumWidthRequest="500" 
                                    HorizontalOptions="Center"
                                    Padding="0">
                                    <Image
                                        Source="{Binding ImageSource}"
                                        Aspect="AspectFill"/>
                                </Border>
                                
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>