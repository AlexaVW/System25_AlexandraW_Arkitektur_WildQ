<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WildQ.Presentation.Views.SearchAnimalPage"
             Title="SearchAnimalPage"
             BackgroundColor="DarkOliveGreen">
    <ScrollView >
        <VerticalStackLayout MaximumWidthRequest="700" Margin="25" Spacing="20" HorizontalOptions="Center">
            
            <Label 
                Text="Search for an animal and get information about it"
                TextColor="Wheat"
                Style="{StaticResource SubHeadline}"
                HorizontalOptions="Center"/>

            <FlexLayout
                Wrap="Wrap"
                JustifyContent="Center"
                Direction="Row"
                Margin="10"
                HorizontalOptions="Center">
                <Button
                    Text="Go Back"
                    Clicked="OnClickedGoBackToMainPage"
                    Style="{StaticResource NavButtonBrown}"
                    Margin="4"/>

                <Entry
                    x:Name="entryAnimalName"
                    Text="{Binding AnimalNameInput}"
                    Placeholder="Enter an animal spieces"
                    MaximumWidthRequest="235"
                    Margin="4"/>

                <Button 
                    Command ="{Binding SearchAnimalCommand}"
                    Text="Search for animal"
                    BackgroundColor="Wheat"
                    TextColor="DarkOliveGreen"
                    Margin="4"/>
            </FlexLayout>

            <CollectionView ItemsSource="{Binding Animals}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            StrokeShape="RoundRectangle 30"
                            BackgroundColor="Wheat"
                            MaximumWidthRequest="700"
                            Padding="15">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Label 
                                Text="{Binding Name}"
                                Style="{StaticResource SubHeadline}"
                                FontSize="30"
                                TextColor="Black"/>
                            <Label
                                Text="{Binding Characteristics.Name_of_young ,
                                StringFormat='Name of Young: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Group_behavior,
                                StringFormat='Group Behavior: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Estimated_population_size,
                                StringFormat='Estimated Population Size: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Gestation_period,
                                StringFormat='Gestation Period: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Litter_size,
                                StringFormat='Litter Size: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Diet,
                                StringFormat='Diet: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Location,
                                StringFormat='Location: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Top_speed,
                                StringFormat='Top Speed: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Lifespan,
                                StringFormat='Lifespan: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Weight,
                                StringFormat='Weight: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Height,
                                StringFormat='Height: {0}'}"
                                HorizontalOptions="Center"/>
                            <Label
                                Text="{Binding Characteristics.Age_of_sexual_maturity,
                                StringFormat='Age of Sexual Maturity: {0}'}"
                                HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>