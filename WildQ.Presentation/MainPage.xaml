<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WildQ.Presentation.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Button
                Text="Get data"
                Clicked="ClickedOnGetData"/>

            <CollectionView
                x:Name="CollectionViewAnimals">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout>
                            <Label
                                Text="{Binding Id}"/>
                            <Label
                                Text="{Binding AnimalName}"/>
                        </HorizontalStackLayout>
                        
                        
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
            </CollectionView>

            <Entry
                x:Name="EntryAnimalName"
                Placeholder="Enter Animal Name"/>

            <Entry
                x:Name="EntryImageUrl"
                Placeholder="Enter ImageUrl"/>

            <Button
                Text="Add animal"
                Clicked="OnClickedAddAnimal"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
